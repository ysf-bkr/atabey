# Agent Atabey — Environment Variables
# Copy this file to .env and adjust values for your environment.
# .env is in .gitignore and will NOT be committed.

# ─── Server Configuration ─────────────────────────────────────────
# MCP Transport mode: "unified" (default, MCP+Dashboard on single port) or "stdio"
# MCP_TRANSPORT=unified

# Server host (0.0.0.0 = all network interfaces, localhost = local only)
# MCP_HOST=0.0.0.0

# Server port (default: 5858 for unified mode)
# MCP_PORT=5858

# Project root directory (required in SSE/network mode)
# ATABEY_PROJECT_ROOT=/path/to/your/project

# Framework directory (optional, default: .atabey in project root)
# ATABEY_FRAMEWORK_DIR=.atabey

# Node environment (production/development/test)
# NODE_ENV=development

# ─── Security / Authentication ────────────────────────────────────
# Master API key for MCP server authentication.
# If set, all API and MCP requests require Authorization: Bearer <token> header.
# MCP_AUTH_TOKEN=

# Per-user API tokens (comma-separated, format: user1:token1,user2:token2)
# MCP_AUTH_USERS=

# ─── AI Discipline Engine ─────────────────────────────────────────
# Max tool calls per minute per agent (default: 60)
# MCP_MAX_CALLS_PER_MINUTE=60

# Max total tool calls per session (default: 500)
# MCP_MAX_TOTAL_CALLS=500

# Max file size for read/write in bytes (default: 1048576 = 1MB)
# MCP_MAX_FILE_SIZE=1048576

# Max args size for any tool call in bytes (default: 102400 = 100KB)
# MCP_MAX_ARGS_SIZE=102400

# Cooldown period after limit hit in ms (default: 30000 = 30s)
# MCP_COOLDOWN_MS=30000

# Max response size in bytes (default: 512000 = 500KB)
# MCP_MAX_RESPONSE_SIZE=512000

# Max consecutive same tool calls before loop detection (default: 10)
# MCP_MAX_CONSECUTIVE_SAME_TOOL=10

# Restricted tools (comma-separated, always blocked)
# MCP_RESTRICTED_TOOLS=run_shell_command,check_active_ports

# Agent-based tool whitelist (format: agent1:tool1,tool2;agent2:tool3,tool4)
# MCP_AGENT_TOOL_WHITELIST=

# ─── AI Provider Keys ─────────────────────────────────────────────
# OpenAI API key (used for embeddings)
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ─── Data Retention ───────────────────────────────────────────────
# How long to keep audit logs, messages, and records (in days, default: 30)
# ATABEY_DATA_RETENTION_DAYS=30
