{
  "name": "atabey",
  "version": "0.0.24",
  "description": "Atabey — AI Governance & Multi-Agent Platform / Orchestrator — Core Engine",
  "author": "Yusuf BEKAR",
  "license": "AGPL-3.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "claude-code",
    "cursor-ide",
    "gemini-cli",
    "governance",
    "orchestration",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysf-bkr/atabey.git",
    "directory": "packages/atabey"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "atabey": "bin/cli.js"
  },
  "main": "./dist/atabey/src/cli/index.js",
  "types": "./dist/atabey/src/cli/index.d.ts",
  "exports": {
    ".": "./dist/atabey/src/cli/index.js"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md",
    "LICENSE",
    "ATABEY.md",
    "PRIVACY.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "atabey-shared": "^0.0.24",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.1",
    "chalk": "^5.6.2",
    "js-yaml": "^4.2.0",
    "ws": "^8.21.0",
    "zod": "^3.24.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.22.3",
    "vitest": "^3.0.0"
  }
}
