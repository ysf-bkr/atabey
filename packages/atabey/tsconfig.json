{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "atabey-shared": ["../shared/src/index.ts"],
      "atabey-shared/*": ["../shared/src/*"],
      "atabey-mcp/src/mcp/utils/*": ["../atabey-mcp/src/mcp/utils/*"],
      "atabey-mcp/src/shared/*": ["../atabey-mcp/src/shared/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
