{
  "name": "atabey-mcp",
  "version": "0.0.19",
  "description": "MCP-Powered AI Governance & Autonomous Orchestration Framework — MCP Server",
  "author": "Yusuf BEKAR",
  "license": "AGPL-3.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "claude-code",
    "cursor-ide",
    "gemini-cli",
    "governance",
    "orchestration",
    "typescript"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysf-bkr/atabey.git"
  },
  "bin": {
    "atabey-mcp": "./bin/cli.js"
  },
  "main": "./dist/atabey-mcp/src/mcp/index.js",
  "exports": {
    ".": "./dist/atabey-mcp/src/mcp/index.js",
    "./utils/*": "./dist/atabey-mcp/src/mcp/utils/*",
    "./shared/*": "./dist/atabey-mcp/src/shared/*",
    "./src/mcp/utils/*": "./dist/atabey-mcp/src/mcp/utils/*",
    "./src/shared/*": "./dist/atabey-mcp/src/shared/*"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "atabey-shared": "*",
    "atabey": "*"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.1",
    "chalk": "^5.6.2",
    "js-yaml": "^4.2.0",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
