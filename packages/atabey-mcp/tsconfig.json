{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ESNext"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "atabey-shared": ["../shared/src/index.ts"],
      "atabey-shared/*": ["../shared/src/*"],
      "atabey/*": ["../atabey/src/*"],
      "atabey/src/*": ["../atabey/src/*"],
      "atabey-mcp/utils/*": ["src/mcp/utils/*"],
      "atabey-mcp/shared/*": ["src/shared/*"],
      "atabey-mcp/*": ["src/mcp/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
