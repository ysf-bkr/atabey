{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ESNext"],
    "strict": false,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "atabey/*": ["../atabey/src/*"],
      "atabey/src/*": ["../atabey/src/*"],
      "../../modules/*": ["../atabey/src/modules/*"],
      "../cli/utils/*": ["src/mcp/utils/*"],
      "../cli/utils/time.js": ["../atabey/src/cli/utils/time.ts"],
      "../cli/utils/compliance.js": ["src/mcp/utils/compliance.ts"],
      "../cli/utils/quality.js": ["src/mcp/utils/quality.ts"],
      "../../cli/commands/orchestrate.js": ["../atabey/src/cli/commands/orchestrate.ts"],
      "../../modules/skills/adapter-skills.js": ["../atabey/src/modules/skills/adapter-skills.ts"],
      "../../modules/engines/risk-engine.js": ["../atabey/src/modules/engines/risk-engine.ts"],
      "../../modules/memory/core.js": ["../atabey/src/modules/memory/core.ts"],
      "../../modules/engines/crud-governance.js": ["../atabey/src/modules/engines/crud-governance.ts"],
      "../../modules/engines/*": ["../atabey/src/modules/engines/*"],
      "../../modules/memory/*": ["../atabey/src/modules/memory/*"],
      "../../modules/skills/*": ["../atabey/src/modules/skills/*"],
      "../../modules/agents/*": ["../atabey/src/modules/agents/*"],
      "../../cli/commands/*": ["../atabey/src/cli/commands/*"],
      "atabey-mcp/../src/shared/*": ["src/shared/*"],
      "atabey-mcp/../modules/*": ["../atabey/src/modules/*"],
      "atabey-mcp/../cli/utils/*": ["../atabey/src/cli/utils/*"],
      "atabey-mcp/utils/*": ["src/mcp/utils/*"],
      "atabey-mcp/shared/*": ["src/shared/*"],
      "atabey-mcp/*": ["src/mcp/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
