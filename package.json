{
  "name": "atabey-monorepo",
  "version": "0.0.16",
  "description": "MCP-Powered AI Governance & Autonomous Orchestration Framework — Monorepo",
  "author": "Yusuf BEKAR",
  "license": "AGPL-3.0",
  "readme": "README.md",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysf-bkr/atabey.git"
  },
  "homepage": "https://github.com/ysf-bkr/atabey#readme",
  "bugs": {
    "url": "https://github.com/ysf-bkr/atabey/issues"
  },
  "workspaces": [
    "packages/atabey",
    "packages/atabey-mcp"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:atabey": "npm run build -w packages/atabey",
    "build:mcp": "npm run build -w packages/atabey-mcp",
    "build:dashboard": "npm run build -w packages/atabey-mcp dashboard",
    "lint": "eslint packages/",
    "test": "npm run test --workspaces --if-present",
    "test:atabey": "npm run test -w packages/atabey",
    "test:mcp": "npm run test -w packages/atabey-mcp",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist",
    "atabey:status": "npm run atabey -w packages/atabey status",
    "atabey:check": "npm run atabey -w packages/atabey check",
    "atabey:test": "npm run test:atabey",
    "atabey:build": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.2.6"
  },
  "atabey": {
    "version": "0.0.16",
    "initializedAt": "2026-06-25T11:05:00.000Z"
  }
}
